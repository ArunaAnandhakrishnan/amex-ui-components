              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "wearables",
                "devices",
                "3744 XXXXXX 9008"
              ]
            },
            "description": "Requires ROLE_CSA or ROLE_ONLS_ADMIN. Replace card number with one from V2__seed_data.sql."
          },
          "response": []
        },
        {
          "name": "Issue Wearable",
          "request": {
            "method": "POST",
