        {
          "name": "Login – sys.admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "    pm.collectionVariables.set('userId', res.data.userId);",
                  "    console.log('Tokens saved | User: ' + res.data.username + ' | Roles: ' + res.data.roles);",
