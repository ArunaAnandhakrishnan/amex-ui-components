            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientCode\": \"12345\",\n  \"selectedCard\": \"3744 XXXXXX 9008\",\n  \"wearableType\": \"ring\",\n  \"colorSelected\":\"white\",\n  \"wearableName\": \"white Ring\",\n  \"tcAccepted\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/wearables/issue",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "wearables",
                "issue"
              ]
            },
            "description": "Requires ROLE_CSA only. tcAccepted must be true."
          },
          "response": []
        },
